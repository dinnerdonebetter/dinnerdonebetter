{
  "name": "consumer",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:unit": "vitest",
    "test:run": "vitest run --project server",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "verify": "npm run format:check && npm run lint && npm run check && npm run test:run && npm run build",
    "verify:e2e": "npm run build && npm run test:e2e",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@dinnerdonebetter/api-client": "file:../packages/api-client",
    "@dinnerdonebetter/branding": "file:../packages/branding",
    "@dinnerdonebetter/logger": "file:../packages/logger",
    "@dinnerdonebetter/ui": "file:../packages/ui",
    "@grpc/grpc-js": "1.14.3",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "0.57.2",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.57.2",
    "@opentelemetry/instrumentation-http": "0.57.2",
    "@opentelemetry/resources": "1.30.1",
    "@opentelemetry/sdk-metrics": "1.30.1",
    "@opentelemetry/sdk-node": "0.57.2",
    "@opentelemetry/semantic-conventions": "1.40.0",
    "marked": "17.0.4",
    "mermaid": "11.13.0"
  },
  "devDependencies": {
    "@dinnerdonebetter/eslint-config-custom": "file:../packages/eslint-config-custom",
    "@eslint/compat": "2.0.3",
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.58.2",
    "@sveltejs/adapter-node": "5.5.4",
    "@sveltejs/kit": "2.55.0",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@types/node": "25.5.0",
    "@vitest/browser-playwright": "4.1.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.15.2",
    "globals": "17.4.0",
    "playwright": "1.58.2",
    "prettier": "3.8.1",
    "prettier-plugin-svelte": "3.5.1",
    "svelte": "5.53.11",
    "svelte-check": "4.4.5",
    "ts-proto": "2.11.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vite": "7.3.1",
    "vitest": "4.1.0",
    "vitest-browser-svelte": "2.1.0"
  }
}
