{
  "name": "consumer",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:unit": "vitest",
    "test:run": "vitest run --project server",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "verify": "npm run format:check && npm run lint && npm run check && npm run test:run && npm run build",
    "verify:e2e": "npm run build && npm run test:e2e",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@dinnerdonebetter/api-client": "file:../packages/api-client",
    "@dinnerdonebetter/logger": "file:../packages/logger",
    "@dinnerdonebetter/ui": "file:../packages/ui",
    "@grpc/grpc-js": "^1.12.4",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.57.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.29.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/sdk-trace-web": "^1.29.0",
    "@opentelemetry/semantic-conventions": "^1.29.0",
    "marked": "^17.0.4",
    "mermaid": "^11.4.0"
  },
  "devDependencies": {
    "@dinnerdonebetter/eslint-config-custom": "file:../packages/eslint-config-custom",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^22",
    "@vitest/browser-playwright": "^4.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.3.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "ts-proto": "^2.5.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "vitest-browser-svelte": "^2.0.2"
  }
}
