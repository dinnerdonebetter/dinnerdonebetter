# gRPC API server URL (host:port).
# Production: api.dinnerdonebetter.com:443 (with DEVELOPING_LOCALLY=false)
# Local dev: localhost:50051 after port-forward (kubectl port-forward svc/api-service 50051:50051)
GRPC_API_SERVER_URL=

# HTTP API server URL for OAuth2 token exchange (e.g. https://api.dinnerdonebetter.com)
HTTP_API_SERVER_URL=

# OAuth2 client credentials (same as Go consumer webapp)
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=

# Cookie encryption: base64-encoded 32-byte key for AES-256-GCM
# Generate with: openssl rand -base64 32
COOKIE_ENCRYPTION_KEY=

# Cookie name (default: consumer_session)
COOKIE_NAME=consumer_session

# Cookie domain (optional, empty for current host)
COOKIE_DOMAIN=

# Set to "true" for local dev: uses plaintext gRPC instead of TLS
DEVELOPING_LOCALLY=false
