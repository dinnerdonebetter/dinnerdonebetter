# gRPC API server URL (host:port). For local dev with port-forward: localhost:50051
GRPC_API_SERVER_URL=api.dinnerdonebetter.com:443

# HTTP API server URL for OAuth2 token exchange (e.g. https://api.dinnerdonebetter.com)
HTTP_API_SERVER_URL=https://http-api.dinnerdonebetter.com

# OAuth2 client credentials (same as Go consumer webapp)
OAUTH2_CLIENT_ID=1c3fdb3a10c4b8bffcfbfc8cb8e796f5
OAUTH2_CLIENT_SECRET=253e0a7521d7f409e6808ee980f47f9a

# Cookie encryption: base64-encoded 32-byte key for AES-256-GCM.
# Generate with: openssl rand -base64 32
COOKIE_ENCRYPTION_KEY=XjZH3eVWVbWjglTJba2JFcviWv+8TBJ6HgcfiI9gEJE

# Cookie name (default: admin_webapp)
COOKIE_NAME=admin_webapp

# Cookie domain (optional, e.g. admin.dinnerdonebetter.com)
COOKIE_DOMAIN=localhost

# Set to 'true' for local dev (insecure gRPC)
DEVELOPING_LOCALLY=false
PUBLIC_AVATAR_MEDIA_URL_PREFIX=https://media.dinnerdonebetter.com/avatars
