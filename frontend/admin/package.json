    "@eslint/compat": "2.0.3",
    "@eslint/js": "9.39.4",
    "@sveltejs/adapter-node": "5.5.4",
    "@sveltejs/kit": "2.55.0",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@types/node": "25.5.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.15.2",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-svelte": "3.5.1",
    "svelte": "5.53.11",
    "svelte-check": "4.4.5",
    "typescript": "5.9.3",
