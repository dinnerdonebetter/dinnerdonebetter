# gRPC API server URL (host:port).
# Production: api.dinnerdonebetter.com:443
# Local dev: localhost:50051 after port-forward (kubectl port-forward svc/dinner-done-better-api-svc 50051:8001)
GRPC_API_SERVER_URL=

# HTTP API server URL for OAuth2 token exchange (e.g. https://http-api.dinnerdonebetter.com)
HTTP_API_SERVER_URL=

# OAuth2 client credentials (same as Go admin webapp)
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=

# Cookie encryption: base64-encoded 32-byte key for AES-256-GCM
# Generate with: openssl rand -base64 32
COOKIE_ENCRYPTION_KEY=

# Cookie name (default: admin_webapp)
COOKIE_NAME=admin_webapp

# Cookie domain (optional, e.g. admin.dinnerdonebetter.com)
COOKIE_DOMAIN=admin.dinnerdonebetter.com
