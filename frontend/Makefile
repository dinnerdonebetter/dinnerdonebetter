.PHONY: check test lint lint-fix format format-check install

# Run svelte-check in both consumer and admin
check:
	npm run check

# Run unit tests in both consumer and admin
test:
	npm run test

# Lint both apps
lint:
	npm run lint

# Lint with auto-fix
lint-fix:
	npm run lint:fix

# Format all code
format:
	npm run format

# Check formatting only
format-check:
	npm run format:check

# Install dependencies (from frontend root)
install:
	npm install
