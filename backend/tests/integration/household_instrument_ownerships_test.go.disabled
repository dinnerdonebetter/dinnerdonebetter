package integration

import (
	"testing"

	"github.com/dinnerdonebetter/backend/internal/platform/observability/tracing"
	"github.com/dinnerdonebetter/backend/pkg/types"
	"github.com/dinnerdonebetter/backend/pkg/types/converters"
	"github.com/dinnerdonebetter/backend/pkg/types/fakes"

	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"
)

func checkAccountInstrumentOwnershipEquality(t *testing.T, expected, actual *types.AccountInstrumentOwnership) {
	t.Helper()

	assert.NotZero(t, actual.ID)
	assert.Equal(t, expected.Notes, actual.Notes, "expected Notes for account instrument ownership %s to be %v, but it was %v", expected.ID, expected.Notes, actual.Notes)
	assert.Equal(t, expected.Instrument.ID, actual.Instrument.ID, "expected Vessel.ID for account instrument ownership %s to be %v, but it was %v", expected.ID, expected.Instrument.ID, actual.Instrument.ID)
	assert.Equal(t, expected.Quantity, actual.Quantity, "expected Quantity for account instrument ownership %s to be %v, but it was %v", expected.ID, expected.Quantity, actual.Quantity)
	assert.NotZero(t, actual.CreatedAt)
}

func (s *TestSuite) TestAccountInstrumentOwnerships_CompleteLifecycle() {
	s.runTest("should CRUD", func(testClients *testClientWrapper) func() {
		return func() {
			t := s.T()

			ctx, span := tracing.StartCustomSpan(s.ctx, t.Name())
			defer span.End()

			createdValidInstrument := createValidInstrumentForTest(t, ctx, testClients.adminClient)

			exampleAccountInstrumentOwnership := fakes.BuildFakeAccountInstrumentOwnership()
			exampleAccountInstrumentOwnership.Instrument = *createdValidInstrument
			exampleAccountInstrumentOwnershipInput := converters.ConvertAccountInstrumentOwnershipToAccountInstrumentOwnershipCreationRequestInput(exampleAccountInstrumentOwnership)
			createdAccountInstrumentOwnership, err := testClients.adminClient.CreateAccountInstrumentOwnership(ctx, exampleAccountInstrumentOwnershipInput)
			require.NoError(t, err)
			checkAccountInstrumentOwnershipEquality(t, exampleAccountInstrumentOwnership, createdAccountInstrumentOwnership)

			newAccountInstrumentOwnership := fakes.BuildFakeAccountInstrumentOwnership()
			newAccountInstrumentOwnership.Instrument = *createdValidInstrument
			updateInput := converters.ConvertAccountInstrumentOwnershipToAccountInstrumentOwnershipUpdateRequestInput(newAccountInstrumentOwnership)
			createdAccountInstrumentOwnership.Update(updateInput)
			assert.NoError(t, testClients.adminClient.UpdateAccountInstrumentOwnership(ctx, createdAccountInstrumentOwnership.ID, updateInput))

			actual, err := testClients.adminClient.GetAccountInstrumentOwnership(ctx, createdAccountInstrumentOwnership.ID)
			requireNotNilAndNoProblems(t, actual, err)

			// assert account instrument ownership equality
			checkAccountInstrumentOwnershipEquality(t, newAccountInstrumentOwnership, actual)
			assert.NotNil(t, actual.LastUpdatedAt)

			assert.NoError(t, testClients.adminClient.ArchiveAccountInstrumentOwnership(ctx, createdAccountInstrumentOwnership.ID))
		}
	})
}

func (s *TestSuite) TestAccountInstrumentOwnerships_Listing() {
	s.runTest("should be readable in paginated form", func(testClients *testClientWrapper) func() {
		return func() {
			t := s.T()

			ctx, span := tracing.StartCustomSpan(s.ctx, t.Name())
			defer span.End()

			var expected []*types.AccountInstrumentOwnership
			for i := 0; i < 5; i++ {
				createdValidInstrument := createValidInstrumentForTest(t, ctx, testClients.adminClient)

				exampleAccountInstrumentOwnership := fakes.BuildFakeAccountInstrumentOwnership()
				exampleAccountInstrumentOwnership.Instrument = *createdValidInstrument
				exampleAccountInstrumentOwnershipInput := converters.ConvertAccountInstrumentOwnershipToAccountInstrumentOwnershipCreationRequestInput(exampleAccountInstrumentOwnership)
				createdAccountInstrumentOwnership, err := testClients.adminClient.CreateAccountInstrumentOwnership(ctx, exampleAccountInstrumentOwnershipInput)
				require.NoError(t, err)
				checkAccountInstrumentOwnershipEquality(t, exampleAccountInstrumentOwnership, createdAccountInstrumentOwnership)

				expected = append(expected, createdAccountInstrumentOwnership)
			}

			// assert account instrument ownership list equality
			actual, err := testClients.adminClient.GetAccountInstrumentOwnerships(ctx, nil)
			requireNotNilAndNoProblems(t, actual, err)
			assert.True(
				t,
				len(expected) <= len(actual.Data),
				"expected %d to be <= %d",
				len(expected),
				len(actual.Data),
			)

			for _, createdAccountInstrumentOwnership := range expected {
				assert.NoError(t, testClients.adminClient.ArchiveAccountInstrumentOwnership(ctx, createdAccountInstrumentOwnership.ID))
			}
		}
	})
}
