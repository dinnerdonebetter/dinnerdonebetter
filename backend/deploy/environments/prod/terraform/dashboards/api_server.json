{
  "title": "API Server",
  "uid": "ddb-api-server",
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "annotations": {
    "list": [
      {
        "builtIn": 0,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": false,
        "iconColor": "blue",
        "name": "Deployments",
        "target": { "limit": 100, "matchAny": true, "tags": ["deployment", "production"], "type": "tags" },
        "type": "tags"
      },
      {
        "builtIn": 0,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": false,
        "iconColor": "orange",
        "name": "Terraform",
        "target": { "limit": 100, "matchAny": true, "tags": ["terraform", "infra", "backend-infra"], "type": "tags" },
        "type": "tags"
      }
    ]
  },
  "panels": [
    {
      "title": "DB Query Rate",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(db_sql_latency_milliseconds_count{job=\"api_server\"}[5m]))",
          "legendFormat": "Queries/s"
        }
      ]
    },
    {
      "title": "DB Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum(rate(db_sql_latency_milliseconds_bucket{job=\"api_server\"}[5m])) by (le))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum(rate(db_sql_latency_milliseconds_bucket{job=\"api_server\"}[5m])) by (le))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum(rate(db_sql_latency_milliseconds_bucket{job=\"api_server\"}[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "title": "Deployment Replicas",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "targets": [
        { "refId": "A", "expr": "kube_deployment_status_replicas_available{namespace=\"prod\", deployment=~\"dinner-done-better-service-api.*\"}", "legendFormat": "{{deployment}} available" },
        { "refId": "B", "expr": "kube_deployment_spec_replicas{namespace=\"prod\", deployment=~\"dinner-done-better-service-api.*\"}", "legendFormat": "{{deployment}} desired" }
      ]
    },
    {
      "title": "Go Goroutines",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "targets": [
        { "refId": "A", "expr": "process_runtime_go_goroutines{job=\"api_server\"}", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "title": "Go Heap Allocated",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 6 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "targets": [
        { "refId": "A", "expr": "process_runtime_go_mem_heap_alloc_bytes{job=\"api_server\"}", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "title": "Go GC Pause (p99)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ns",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.99, sum(rate(process_runtime_go_gc_pause_ns_bucket{job=\"api_server\"}[5m])) by (le, instance))", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "title": "Host CPU",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "targets": [
        { "refId": "A", "expr": "sum(rate(system_cpu_time_seconds_total{job=\"api_server\"}[5m])) by (instance) * 100", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "title": "Host Memory",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "targets": [
        { "refId": "A", "expr": "system_memory_usage_bytes{job=\"api_server\"}", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "title": "Memory Utilization",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "targets": [
        { "refId": "A", "expr": "system_memory_utilization_ratio{job=\"api_server\"}", "legendFormat": "{{instance}}" }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 0
}
