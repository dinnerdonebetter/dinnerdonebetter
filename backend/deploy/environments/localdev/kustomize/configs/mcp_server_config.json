				"enableRuntimeMetrics": false,
				"enableHostMetrics": false
			},
			"serviceName": "dinner_done_better_mcp_server",
			"provider": "otelgrpc"
		},
		"tracing": {
			"otelgrpc": {
				"collector_endpoint": "otel_collector:4317",
				"insecure": true
			},
			"service_name": "dinner_done_better_mcp_server",
			"provider": "otelgrpc",
			"spanCollectionProbability": 1
		}
	},
	"routing": {
		"chiConfig": {
			"serviceName": "dinner_done_better_mcp_server",
