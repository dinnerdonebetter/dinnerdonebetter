		"grpcAPIServerURL": ":8001",
		"username": "",
		"password": "",
		"oauth2APIClientID": "",
		"oauth2APIClientSecret": ""
	},
	"observability": {
		"profiling": {
			"pprof": {
				"port": 6060,
				"enableMutexProfile": false,
				"enableBlockProfile": false
			},
			"serviceName": "dinner_done_better_mcp_server",
			"provider": "pprof"
		},
		"logging": {
			"serviceName": "dinner_done_better_mcp_server",
			"level": "debug",
			"otelslog": {
				"endpointURL": "otel_collector:4317",
