// Secrets.xcconfig
// Copy this file to Secrets.xcconfig and fill in your values.
// Do NOT commit Secrets.xcconfig to git.
//
// Segment write key: Connections → Sources → [Apple source] → Write Key
// USE_ANALYTICS_BACKEND: set to 1 to use backend analytics passthrough (requires proxySources.ios configured)

OAUTH2_CLIENT_ID = your-client-id-here
OAUTH2_CLIENT_SECRET = your-client-secret-here
SEGMENT_WRITE_KEY = your-segment-write-key-here
REVENUECAT_API_KEY = your-revenuecat-api-key-here
// USE_ANALYTICS_BACKEND = 1
